# Vite 3D app — set VITE_API_URL in Cloudflare Pages
# (Settings → Environment variables). Baked into the bundle at build time.
# The /api suffix is included — this app's API client prepends paths to it.

# Prod (Production environment, main branch)
VITE_API_URL=https://api.knownyourancestry.com/api

# Dev (Preview environment, dev branch)
# VITE_API_URL=https://dev.api.knownyourancestry.com/api

# Frontend (Next.js) origin — where unauthenticated/expired visitors are sent
# to log in. After login the frontend re-opens this app with a fresh token in
# the URL hash. No /login suffix — the app appends it.
VITE_FRONTEND_URL=https://knownyourancestry.com
